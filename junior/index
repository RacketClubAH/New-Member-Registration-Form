<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Junior Tennis Membership Registration Form 2026</title>
  <style>
    :root {
      --bg: #f4f1eb;
      --card: #fbf9f5;
      --stroke: rgba(78, 69, 58, 0.16);
      --text: #4a443d;
      --muted: #7b7369;
      --accent: #6a6358;
      --bar: #dcd6cb;
      --option: #f1ece3;
      --selected: #ece5d8;
      --button: #655b4e;
      --white: #ffffff;
      --success-bg: #e8f5ea;
      --success-text: #2d6a39;
      --success-border: #bfdcc5;
      --error-bg: #fdeceb;
      --error-text: #9d2e2b;
      --error-border: #edc2bf;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Arial, sans-serif;
    }

    body {
      min-height: 100vh;
    }

    .app {
      max-width: 920px;
      margin: 0 auto;
      padding: 22px 16px 40px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--stroke);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    }

    .top {
      padding: 24px 24px 12px;
      text-align: center;
      background: var(--card);
    }

    .logo {
      max-width: 300px;
      max-height: 90px;
      width: auto;
      height: auto;
    }

    .title-bar {
      background: var(--bar);
      color: #666057;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      font-size: 14px;
      font-weight: bold;
      padding: 14px 16px;
      text-align: center;
    }

    .content {
      padding: 18px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .field {
      background: var(--card);
      border: 1px solid var(--stroke);
      border-radius: 16px;
      padding: 12px;
    }

    .field.full {
      grid-column: 1 / -1;
    }

    .label {
      display: block;
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-weight: bold;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .input {
      width: 100%;
      border: 1px solid rgba(78, 69, 58, 0.16);
      border-radius: 12px;
      background: #fff;
      color: var(--text);
      font-size: 16px;
      padding: 14px 12px;
      outline: none;
      appearance: none;
    }

    .input:focus {
      border-color: #9f9587;
      box-shadow: 0 0 0 3px rgba(159, 149, 135, 0.14);
    }

    .panel {
      margin-top: 14px;
      background: var(--card);
      border: 1px solid var(--stroke);
      border-radius: 18px;
      padding: 14px;
    }

    .section-title {
      font-size: 17px;
      font-weight: bold;
      color: var(--accent);
      margin: 0 0 12px 0;
    }

    .membership-option {
      margin-bottom: 10px;
    }

    .membership-option input[type="radio"] {
      display: none;
    }

    .membership-label {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px;
      border-radius: 14px;
      background: var(--option);
      border: 1px solid rgba(78,69,58,0.08);
      cursor: pointer;
      transition: 0.15s ease;
    }

    .membership-option input[type="radio"]:checked + .membership-label {
      border: 2px solid var(--button);
      background: var(--selected);
    }

    .membership-name {
      font-size: 15px;
      font-weight: bold;
      color: var(--text);
      line-height: 1.4;
    }

    .membership-price {
      color: var(--muted);
      font-weight: bold;
      white-space: nowrap;
      margin-left: 12px;
      font-size: 15px;
    }

    .disclaimer-box {
      font-size: 14px;
      line-height: 1.65;
      color: var(--text);
      background: var(--option);
      border: 1px solid rgba(78,69,58,0.08);
      border-radius: 14px;
      padding: 14px;
      margin-bottom: 12px;
    }

    .checkbox-row {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      background: var(--white);
      border: 1px solid rgba(78,69,58,0.10);
      border-radius: 12px;
      padding: 12px;
      font-size: 14px;
      font-weight: bold;
      line-height: 1.5;
    }

    .checkbox-row input[type="checkbox"] {
      width: 22px;
      height: 22px;
      margin-top: 1px;
      flex: 0 0 auto;
      accent-color: var(--button);
    }

    .signature-box {
      width: 100%;
      height: 180px;
      background: linear-gradient(180deg, rgba(255,255,255,0.55), rgba(241,236,227,0.9));
      border: 1px dashed rgba(101,91,78,0.22);
      border-radius: 12px;
      display: block;
      touch-action: none;
    }

    .helper {
      font-size: 12px;
      color: var(--muted);
      margin-top: 8px;
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    button {
      border: 0;
      border-radius: 14px;
      padding: 14px 18px;
      font-size: 15px;
      font-weight: bold;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--button);
      color: #fff;
      flex: 1 1 220px;
    }

    .btn-secondary {
      background: #e7e0d5;
      color: var(--text);
      flex: 1 1 180px;
    }

    .btn-primary:disabled,
    .btn-secondary:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .status {
      display: none;
      margin-top: 14px;
      border-radius: 14px;
      padding: 14px;
      font-size: 14px;
      line-height: 1.5;
    }

    .status.success {
      display: block;
      background: var(--success-bg);
      color: var(--success-text);
      border: 1px solid var(--success-border);
    }

    .status.error {
      display: block;
      background: var(--error-bg);
      color: var(--error-text);
      border: 1px solid var(--error-border);
    }

    @media (max-width: 700px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .app {
        padding: 14px 10px 30px;
      }

      .content {
        padding: 14px;
      }

      .title-bar {
        font-size: 12px;
        line-height: 1.5;
      }

      .membership-label {
        align-items: flex-start;
        flex-direction: column;
      }

      .membership-price {
        margin-left: 0;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="card">
      <div class="top">
        <img
          src="https://www.aphroditehills.com/wp-content/uploads/2021/09/AH-Full-Logo-RGB-Bronze.png"
          alt="Aphrodite Hills"
          class="logo"
        />
      </div>

      <div class="title-bar">Junior Tennis Membership Registration Form 2026</div>

      <div class="content">
        <form id="membershipForm">
          <div class="grid">
            <div class="field">
              <label class="label" for="firstName">First Name</label>
              <input class="input" id="firstName" name="firstName" type="text" required />
            </div>

            <div class="field">
              <label class="label" for="lastName">Last Name</label>
              <input class="input" id="lastName" name="lastName" type="text" required />
            </div>

            <div class="field full">
              <label class="label" for="email">Email Address</label>
              <input class="input" id="email" name="email" type="email" required />
            </div>

            <div class="field full">
              <label class="label" for="phoneNumber">Phone Number</label>
              <input class="input" id="phoneNumber" name="phoneNumber" type="text" required />
            </div>

            <div class="field full">
              <label class="label" for="emergencyContact">Emergency Contact</label>
              <input class="input" id="emergencyContact" name="emergencyContact" type="text" required />
            </div>

            <div class="field full">
              <label class="label" for="dateOfBirth">Date of Birth</label>
              <input class="input" id="dateOfBirth" name="dateOfBirth" type="date" required />
            </div>

            <div class="field full">
              <label class="label" for="parentOrTutorName">Parents or legal tutor Name</label>
              <input class="input" id="parentOrTutorName" name="parentOrTutorName" type="text" required />
            </div>

            <div class="field full">
              <label class="label" for="parentOrTutorPhoneNumber">Parents or legal tutor Phone Number</label>
              <input class="input" id="parentOrTutorPhoneNumber" name="parentOrTutorPhoneNumber" type="text" required />
            </div>
          </div>

          <div class="panel">
            <div class="section-title">Tennis Junior Membership (17 years and under)</div>

            <div class="membership-option">
              <input
                type="radio"
                id="membership1"
                name="membershipType"
                value="TENNIS JUNIOR NON-PROPERTY OWNER"
                required
              />
              <label class="membership-label" for="membership1">
                <span class="membership-name">TENNIS JUNIOR NON-PROPERTY OWNER</span>
                <span class="membership-price">EUR 200</span>
              </label>
            </div>

            <div class="membership-option">
              <input
                type="radio"
                id="membership2"
                name="membershipType"
                value="TENNIS JUNIOR PROPERTY OWNER SILVER"
                required
              />
              <label class="membership-label" for="membership2">
                <span class="membership-name">TENNIS JUNIOR PROPERTY OWNER SILVER</span>
                <span class="membership-price">EUR 180</span>
              </label>
            </div>

            <div class="membership-option">
              <input
                type="radio"
                id="membership3"
                name="membershipType"
                value="TENNIS JUNIOR PROPERTY OWNER GOLD"
                required
              />
              <label class="membership-label" for="membership3">
                <span class="membership-name">TENNIS JUNIOR PROPERTY OWNER GOLD</span>
                <span class="membership-price">EUR 170</span>
              </label>
            </div>
          </div>

          <div class="panel">
            <div class="section-title">Disclaimer</div>

            <div class="disclaimer-box">
              By ticking the box below, you confirm that you have read, understood and accepted the Membership Terms and Conditions, Rules and Regulations of Aphrodite Hills Tennis &amp; Spa Ltd, and agree to comply with them at all times. You also consent to Aphrodite Hills Tennis &amp; Spa Ltd sharing or transferring your personal information to our affiliated companies for the purpose of receiving information about news, events, activities, new products, services, advertising campaigns, and promotional activities. You also acknowledge that the Aphrodite Hills Tennis Academy may from time to time be filmed or photographed for publicity purposes, and you consent to your and/or your child’s personal image being used for promotional purposes.
            </div>

            <label class="checkbox-row">
              <input type="checkbox" id="disclaimerAgreed" name="disclaimerAgreed" required />
              <span>I have read and agree to the above disclaimer.</span>
            </label>
          </div>

          <div class="panel">
            <div class="section-title">Signature</div>
            <canvas id="signaturePad" class="signature-box"></canvas>
            <div class="helper">Please sign inside the box above.</div>

            <div class="actions">
              <button type="button" class="btn-secondary" id="clearSignatureBtn">Clear Signature</button>
            </div>
          </div>

          <div class="actions">
            <button type="submit" class="btn-primary" id="submitBtn">Submit Junior Registration</button>
          </div>

          <div id="statusBox" class="status"></div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const WEB_APP_URL = 'PASTE_YOUR_JUNIOR_WEB_APP_URL_HERE';

    const form = document.getElementById('membershipForm');
    const submitBtn = document.getElementById('submitBtn');
    const statusBox = document.getElementById('statusBox');
    const canvas = document.getElementById('signaturePad');
    const clearSignatureBtn = document.getElementById('clearSignatureBtn');
    const ctx = canvas.getContext('2d');

    let isDrawing = false;
    let hasSignature = false;

    function setupCanvas() {
      const ratio = Math.max(window.devicePixelRatio || 1, 1);
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * ratio;
      canvas.height = rect.height * ratio;
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(ratio, ratio);
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.strokeStyle = '#4a443d';
      clearCanvas();
    }

    function clearCanvas() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      hasSignature = false;
    }

    function getPoint(event) {
      const rect = canvas.getBoundingClientRect();
      const touch = event.touches ? event.touches[0] : null;
      const clientX = touch ? touch.clientX : event.clientX;
      const clientY = touch ? touch.clientY : event.clientY;

      return {
        x: clientX - rect.left,
        y: clientY - rect.top
      };
    }

    function startDraw(event) {
      isDrawing = true;
      const point = getPoint(event);
      ctx.beginPath();
      ctx.moveTo(point.x, point.y);
      event.preventDefault();
    }

    function draw(event) {
      if (!isDrawing) return;
      const point = getPoint(event);
      ctx.lineTo(point.x, point.y);
      ctx.stroke();
      hasSignature = true;
      event.preventDefault();
    }

    function stopDraw() {
      isDrawing = false;
    }

    canvas.addEventListener('mousedown', startDraw);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDraw);
    canvas.addEventListener('mouseleave', stopDraw);

    canvas.addEventListener('touchstart', startDraw, { passive: false });
    canvas.addEventListener('touchmove', draw, { passive: false });
    canvas.addEventListener('touchend', stopDraw);
    canvas.addEventListener('touchcancel', stopDraw);

    clearSignatureBtn.addEventListener('click', clearCanvas);
    window.addEventListener('resize', setupCanvas);
    setupCanvas();

    function showStatus(type, message) {
      statusBox.className = 'status ' + type;
      statusBox.textContent = message;
    }

    function getSelectedMembership() {
      const selected = document.querySelector('input[name="membershipType"]:checked');
      return selected ? selected.value : '';
    }

    form.addEventListener('submit', async function (event) {
      event.preventDefault();

      if (!WEB_APP_URL || WEB_APP_URL.includes('https://script.google.com/macros/s/AKfycbxULZUdoJgDdmuEuq2_GD5X6vWhXkMyYg1ag0qu99H9TKSAjAXjPpJpsoKt7ocqD2Nw-g/exec')) {
        showStatus('error', 'Please add the junior web app URL first.');
        return;
      }

      if (!hasSignature) {
        showStatus('error', 'Please sign before submitting the form.');
        return;
      }

      submitBtn.disabled = true;
      showStatus('success', 'Submitting form, please wait...');

      const payload = {
        firstName: document.getElementById('firstName').value.trim(),
        lastName: document.getElementById('lastName').value.trim(),
        email: document.getElementById('email').value.trim(),
        phoneNumber: document.getElementById('phoneNumber').value.trim(),
        emergencyContact: document.getElementById('emergencyContact').value.trim(),
        dateOfBirth: document.getElementById('dateOfBirth').value,
        parentOrTutorName: document.getElementById('parentOrTutorName').value.trim(),
        parentOrTutorPhoneNumber: document.getElementById('parentOrTutorPhoneNumber').value.trim(),
        membershipType: getSelectedMembership(),
        disclaimerAgreed: document.getElementById('disclaimerAgreed').checked,
        signatureCaptured: hasSignature,
        signatureImage: canvas.toDataURL('image/png'),
        termsAcceptedAt: new Date().toISOString(),
        termsVersion: '2026-Junior-Membership-v1'
      };

      try {
        const response = await fetch(WEB_APP_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'text/plain;charset=utf-8'
          },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (!result.success) {
          throw new Error(result.error || 'Submission failed.');
        }

        form.reset();
        clearCanvas();
        showStatus('success', 'Junior membership registration submitted successfully.');
      } catch (error) {
        showStatus('error', 'Submission failed: ' + error.message);
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</body>
</html>
